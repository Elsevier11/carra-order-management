# Database
DATABASE_URL="postgresql://user:pass@localhost:5432/carra_consegne"

# App
PORT=3100
NODE_ENV=development
IMPORT_FILE="./data/consegne.full.json"
ATTACHMENTS_DIR="./data/uploads"
ATTACHMENTS_ALLOWED_EXTENSIONS="pdf,xls,xlsx,csv,txt,jpg,jpeg,png,doc,docx"
ATTACHMENTS_ALLOWED_MIME="application/pdf,application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,text/csv,text/plain,image/jpeg,image/png,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document"

# JWT (da generare dopo)
JWT_SECRET="your-super-secret-jwt-key-here-32-chars-min"

# Optional auth users override (JSON array)
# AUTH_USERS_JSON='[{"username":"admin","role":"admin","passwordHash":"$2a$10$..."}]'
