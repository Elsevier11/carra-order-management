# Database
DATABASE_URL="postgresql://user:pass@localhost:5432/carra_consegne"

# App
PORT=3100
NODE_ENV=development
IMPORT_FILE="./data/consegne.full.json"
ATTACHMENTS_DIR="./data/uploads"
ATTACHMENTS_ALLOWED_EXTENSIONS="pdf,xls,xlsx,csv,txt,jpg,jpeg,png,doc,docx"
ATTACHMENTS_ALLOWED_MIME="application/pdf,application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,text/csv,text/plain,image/jpeg,image/png,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document"
ATTACHMENTS_ALLOWED_EXTENSIONS_ADMIN="pdf,xls,xlsx,csv,txt,jpg,jpeg,png,doc,docx"
ATTACHMENTS_ALLOWED_EXTENSIONS_OPERATIVO="pdf,xls,xlsx,csv,txt,jpg,jpeg,png"
ATTACHMENTS_MAX_SIZE_ADMIN="15728640"
ATTACHMENTS_MAX_SIZE_OPERATIVO="10485760"
ATTACHMENTS_ANTIVIRUS_MODE=""
ATTACHMENTS_ANTIVIRUS_COMMAND=""
ATTACHMENTS_ANTIVIRUS_FAIL_PATTERN="eicar"
ATTACHMENTS_RETENTION_DAYS="365"

# Prod smoke checks
SMOKE_API_BASE="https://your-api-domain"
SMOKE_USERNAME=""
SMOKE_PASSWORD=""
SMOKE_ATTACHMENT_ORDER_ID=""

# JWT (da generare dopo)
JWT_SECRET="your-super-secret-jwt-key-here-32-chars-min"

# SQL Server ERP (import ordini da gestionale)
SQLSERVER_HOST=srvsql
SQLSERVER_PORT=1433
SQLSERVER_DATABASE=ADB_ZEROBYTE
SQLSERVER_USER=
SQLSERVER_PASSWORD=
SQLSERVER_QUERY_TIMEOUT_MS=15000

# Optional auth users override (JSON array)
# AUTH_USERS_JSON='[{"username":"admin","role":"admin","passwordHash":"$2a$10$..."}]'
